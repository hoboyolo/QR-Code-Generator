# pip install qrcode[pil]

import qrcode

url = input("Enter the URL: "). strip()
file_path = "C://Users//James//Desktop//qrcode.png"


qr = qrcode.QRCode()
qr.add_data(url)

qr.make(fit=True)


img = qr.make_image(fill_color="black", back_color="white")
img.save(file_path)

print("QR saved to file")
